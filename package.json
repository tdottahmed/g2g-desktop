{
  "name": "g2g-automation-desktop",
  "version": "1.0.0",
  "description": "G2G.com offer automation — Windows desktop app",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "icon": "node scripts/build-icon.js",
    "build": "node scripts/build-icon.js && electron-builder",
    "build:win": "node scripts/build-icon.js && electron-builder --win",
    "build:dir": "node scripts/build-icon.js && electron-builder --dir",
    "install:browsers": "npx playwright install chromium"
  },
  "dependencies": {
    "dotenv": "^17.0.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "playwright": "^1.55.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.g2g.automation",
    "productName": "G2G Automation",
    "asar": false,
    "artifactName": "${productName} Setup ${version}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "automation/",
        "to": "automation",
        "filter": [
          "**/*",
          "!cookies/**",
          "!.env"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "G2G Automation",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName} Portable ${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "GITHUB_OWNER",
      "repo": "g2g-automation-desktop",
      "releaseType": "release"
    }
  }
}
